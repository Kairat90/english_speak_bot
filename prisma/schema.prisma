generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SkillType {
  SPEAKING
  LISTENING
  VOCABULARY
  GRAMMAR
  READING
  WRITING
}

enum CEFRLevel {
  BEGINNER
  A1
  A2
  B1
  B2
  C1
  C2
}

enum TaskType {
  VOCABULARY_LEARN
  VOCABULARY_TEST
  VOCABULARY_TRANSLATE
  VOCABULARY_SENTENCE
  VOCABULARY_CUSTOM_SENTENCE
  GRAMMAR_EXERCISE
  SPEAKING_TOPIC
  LISTENING_TRANSCRIBE
  LISTENING_RETELL
  LISTENING_QUESTIONS
  READING_COMPREHENSION
  WRITING_ESSAY
  DAILY_CHALLENGE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

enum LessonStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingStep {
  NAME
  GOAL
  DAILY_TIME
  SPEAKING_LEVEL
  LISTENING_LEVEL
  VOCABULARY_LEVEL
  GRAMMAR_LEVEL
  READING_LEVEL
  WRITING_LEVEL
  COMPLETED
}

enum VoiceSubmissionStatus {
  PENDING
  DOWNLOADED
  CONVERTED
  TRANSCRIBED
  ANALYZED
  FAILED
}

enum AchievementType {
  FIRST_LESSON
  STREAK_7
  STREAK_30
  VOCABULARY_100
  SPEAKING_MASTER
  GRAMMAR_GURU
  PERFECT_SCORE
  LEVEL_UP
}

enum DailyChallengeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

// ─── User & Profile ──────────────────────────────────────────────────────────

model User {
  id              String          @id @default(uuid())
  telegramId      BigInt          @unique @map("telegram_id")
  username        String?
  firstName       String?         @map("first_name")
  lastName        String?         @map("last_name")
  displayName     String?         @map("display_name")
  languageCode    String          @default("ru") @map("language_code")
  learningGoal    String?         @map("learning_goal")
  dailyMinutes    Int             @default(15) @map("daily_minutes")
  onboardingStep  OnboardingStep  @default(NAME) @map("onboarding_step")
  isOnboarded     Boolean         @default(false) @map("is_onboarded")
  isActive        Boolean         @default(true) @map("is_active")
  currentState    String?         @map("current_state")
  stateData       Json?           @map("state_data")
  rating          Int             @default(0)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  skills              UserSkill[]
  learningPlans       LearningPlan[]
  lessons             Lesson[]
  taskAttempts        TaskAttempt[]
  vocabularyProgress  VocabularyProgress[]
  grammarProgress     GrammarProgress[]
  listeningProgress   ListeningProgress[]
  speakingProgress    SpeakingProgress[]
  achievements        UserAchievement[]
  dailyChallenges     DailyChallenge[]
  statistics          UserStatistics?
  voiceSubmissions    VoiceSubmission[]
  aiFeedbacks         AiFeedback[]

  @@map("users")
}

model UserSkill {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  skill     SkillType
  level     CEFRLevel @default(BEGINNER)
  score     Float     @default(0)
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@map("user_skills")
}

// ─── Learning Plan & Lessons ─────────────────────────────────────────────────

model LearningPlan {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String?
  focusAreas  Json     @map("focus_areas")
  weeklyGoals Json     @map("weekly_goals")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("learning_plans")
}

model Lesson {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  learningPlanId String?      @map("learning_plan_id")
  skill          SkillType
  title          String
  description    String?
  status         LessonStatus @default(PLANNED)
  orderIndex     Int          @default(0) @map("order_index")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPlan LearningPlan? @relation(fields: [learningPlanId], references: [id], onDelete: SetNull)
  tasks        Task[]

  @@map("lessons")
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  lessonId    String?    @map("lesson_id")
  type        TaskType
  skill       SkillType
  title       String
  content     Json
  level       CEFRLevel
  passScore   Int        @default(70) @map("pass_score")
  maxAttempts Int        @default(3) @map("max_attempts")
  status      TaskStatus @default(PENDING)
  orderIndex  Int        @default(0) @map("order_index")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  lesson         Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  attempts       TaskAttempt[]
  aiFeedbacks    AiFeedback[]
  dailyChallenge DailyChallenge?

  @@map("tasks")
}

model TaskAttempt {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  userId       String   @map("user_id")
  attemptNum   Int      @map("attempt_num")
  userAnswer   String?  @map("user_answer")
  answerType   String   @default("text") @map("answer_type")
  score        Int?
  passed       Boolean  @default(false)
  errors       Json?
  feedback     Json?
  durationSec  Int?     @map("duration_sec")
  createdAt    DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_attempts")
}

// ─── Vocabulary ──────────────────────────────────────────────────────────────

model VocabularyWord {
  id             String    @id @default(uuid())
  word           String
  transcription  String?
  translation    String
  example        String?
  audioUrl       String?   @map("audio_url")
  level          CEFRLevel @default(A1)
  partOfSpeech   String?   @map("part_of_speech")
  tags           String[]  @default([])
  createdAt      DateTime  @default(now()) @map("created_at")

  progress VocabularyProgress[]

  @@unique([word, translation])
  @@map("vocabulary_words")
}

model VocabularyProgress {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  wordId         String    @map("word_id")
  familiarity    Float     @default(0)
  correctCount   Int       @default(0) @map("correct_count")
  wrongCount     Int       @default(0) @map("wrong_count")
  nextReviewAt   DateTime  @default(now()) @map("next_review_at")
  intervalDays   Int       @default(1) @map("interval_days")
  easeFactor     Float     @default(2.5) @map("ease_factor")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  word VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@map("vocabulary_progress")
}

// ─── Skill Progress ──────────────────────────────────────────────────────────

model GrammarProgress {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  topic         String
  level         CEFRLevel
  tasksTotal    Int      @default(0) @map("tasks_total")
  tasksPassed   Int      @default(0) @map("tasks_passed")
  averageScore  Float    @default(0) @map("average_score")
  weakPoints    Json     @default("[]") @map("weak_points")
  lastPracticed DateTime? @map("last_practiced")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
  @@map("grammar_progress")
}

model ListeningProgress {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  level         CEFRLevel
  tasksTotal    Int      @default(0) @map("tasks_total")
  tasksPassed   Int      @default(0) @map("tasks_passed")
  averageScore  Float    @default(0) @map("average_score")
  weakPoints    Json     @default("[]") @map("weak_points")
  lastPracticed DateTime? @map("last_practiced")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, level])
  @@map("listening_progress")
}

model SpeakingProgress {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  level         CEFRLevel
  tasksTotal    Int      @default(0) @map("tasks_total")
  tasksPassed   Int      @default(0) @map("tasks_passed")
  averageScore  Float    @default(0) @map("average_score")
  fluencyScore  Float    @default(0) @map("fluency_score")
  weakPoints    Json     @default("[]") @map("weak_points")
  lastPracticed DateTime? @map("last_practiced")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, level])
  @@map("speaking_progress")
}

// ─── Achievements & Daily Challenges ─────────────────────────────────────────

model Achievement {
  id          String          @id @default(uuid())
  type        AchievementType @unique
  title       String
  description String
  icon        String?
  threshold   Int             @default(1)
  createdAt   DateTime        @default(now()) @map("created_at")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model DailyChallenge {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  taskId    String               @unique @map("task_id")
  date      DateTime             @db.Date
  status    DailyChallengeStatus @default(PENDING)
  score     Int?
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_challenges")
}

// ─── Statistics ──────────────────────────────────────────────────────────────

model UserStatistics {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  tasksCompleted    Int      @default(0) @map("tasks_completed")
  tasksFailed       Int      @default(0) @map("tasks_failed")
  averageScore      Float    @default(0) @map("average_score")
  currentStreak     Int      @default(0) @map("current_streak")
  longestStreak     Int      @default(0) @map("longest_streak")
  totalStudyMinutes Int      @default(0) @map("total_study_minutes")
  lastStudyDate     DateTime? @map("last_study_date")
  errorHistory      Json     @default("[]") @map("error_history")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_statistics")
}

// ─── Voice & AI ──────────────────────────────────────────────────────────────

model VoiceSubmission {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  telegramFileId  String                @map("telegram_file_id")
  originalPath    String?               @map("original_path")
  convertedPath   String?               @map("converted_path")
  transcript      String?
  durationSec     Int?                  @map("duration_sec")
  status          VoiceSubmissionStatus @default(PENDING)
  analysisResult  Json?                 @map("analysis_result")
  errorMessage    String?               @map("error_message")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_submissions")
}

model AiFeedback {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  taskId     String?  @map("task_id")
  promptType String   @map("prompt_type")
  request    Json
  response   Json
  model      String
  tokensUsed Int?     @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("ai_feedbacks")
}
