# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# AI — DeepSeek (https://platform.deepseek.com)
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_deepseek_api_key_here
AI_MODEL=deepseek-chat

# Audio microservice (faster-whisper + edge-tts)
AUDIO_SERVER_URL=http://127.0.0.1:8001
TTS_VOICE=en-US-AriaNeural
WHISPER_MODEL=small

# JWT (internal API auth)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Voice processing
VOICE_TEMP_DIR=./tmp/voice
FFMPEG_PATH=ffmpeg

# Task thresholds
SPEAKING_PASS_THRESHOLD=70
GRAMMAR_PASS_THRESHOLD=70
LISTENING_PASS_THRESHOLD=70
VOCABULARY_PASS_THRESHOLD=70

# Spaced repetition
SRS_INITIAL_INTERVAL_DAYS=1
SRS_EASY_MULTIPLIER=2.5
SRS_HARD_MULTIPLIER=0.5

# Notifications
DAILY_REMINDER_CRON=0 9 * * *
TIMEZONE=Europe/Moscow
